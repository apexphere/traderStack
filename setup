#!/bin/bash
# traderStack setup — symlink skills into Claude Code
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILLS_DIR="${HOME}/.claude/skills"

echo "=== traderStack Setup ==="
echo ""

# Symlink each skill directly into ~/.claude/skills/
for skill in trader-help strategy-thesis backtest strategy-review market-regime; do
  if [ -d "$SCRIPT_DIR/$skill" ]; then
    ln -sfn "$SCRIPT_DIR/$skill" "$SKILLS_DIR/$skill"
    echo "  ✓ /$skill linked"
  fi
done

# Symlink lib (shared Python code)
ln -sfn "$SCRIPT_DIR/lib" "$SKILLS_DIR/traderStack-lib"
echo "  ✓ lib/ linked"

# Python dependencies are handled by OpenQuant's .venv
echo ""
echo "Note: Skills use OpenQuant's jesse CLI. No additional pip installs needed."

# Create traderStack home directory
mkdir -p ~/.traderstack/strategies
mkdir -p ~/.traderstack/graveyard

echo ""
echo "=== Setup Complete ==="
echo ""
echo "Available skills:"
echo "  /trader-help      — Where am I? What should I do next?"
echo "  /market-regime    — Assess current market environment"
echo "  /strategy-thesis  — Brainstorm and challenge a trading thesis"
echo "  /backtest         — Test strategy against historical data"
echo "  /strategy-review  — Adversarial gate before paper trading"
echo ""
echo "Start with: /trader-help"
echo ""
